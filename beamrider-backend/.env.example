# ── Server ──
HOST=0.0.0.0
PORT=8080
API_BASE_URL=http://localhost:8080
REQUEST_BODY_LIMIT_BYTES=65536
ENABLE_WORKERS=false

# ── Database ──
DATABASE_URL=sqlite:./beamrider.db
SQLITE_MAX_CONNECTIONS=5

# ── LLM (Gemini 2.0 Flash free tier) ──
GEMINI_API_KEY=

# ── Chain RPCs ──
CELO_RPC_URL=https://forno.celo.org
CELO_WS_URL=wss://forno.celo.org/ws
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Wallet ──
AGENT_PRIVATE_KEY=
ED25519_SIGNING_KEY=

# ── x402 ──
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402/verify
X402_FACILITATOR_BEARER_TOKEN=
X402_PAY_TO=
X402_PRICE_USDC_ATOMS=100000
COINBASE_CDP_API_KEY=

# ── Contract Addresses (fill after deploy) ──
CELO_REGISTRY_ADDRESS=
CELO_SIGNAL_LEDGER_ADDRESS=
CELO_YIELD_STRATEGY_ADDRESS=
BASE_HOOK_RECEIVER_ADDRESS=
ARBITRUM_HOOK_RECEIVER_ADDRESS=

# ── CCTP V2 (deterministic, same on Base + Arbitrum) ──
CCTP_TOKEN_MESSENGER_V2=0x28b5a0e9C621a5BadaA536219b3a228C8168cf5d
CCTP_MESSAGE_TRANSMITTER_V2=0x81D40F21F12A8F0E3252Bccb954D722d4c464B64
